generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String   // hash bcrypt — nunca retornado na resposta
  role      String   @default("USER") // "USER" | "ADMIN"
  criadoEm DateTime @default(now())

  projetos  Projeto[]
  tarefas   Tarefa[]
}

model Projeto {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  criadoEm DateTime @default(now())

  donoId  String
  dono    User     @relation(fields: [donoId], references: [id], onDelete: Cascade)
  tarefas Tarefa[]
}

model Tarefa {
  id           String    @id @default(cuid())
  titulo       String
  descricao    String?
  prioridade   String    @default("media")  // "baixa" | "media" | "alta"
  status       String    @default("aberta") // "aberta" | "em_andamento" | "concluida"
  dataPrevista DateTime?
  criadaEm    DateTime  @default(now())
  deletadaEm  DateTime?                    // soft delete

  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  donoId String
  dono   User   @relation(fields: [donoId], references: [id], onDelete: Cascade)
}
